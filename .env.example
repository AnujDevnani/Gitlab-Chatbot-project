# ── GitLab Handbook AI — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in the values.

# Required: Anthropic API key (get one at https://console.anthropic.com)

GROQ_API_KEY=your_api_key_here

# Optional: Directory where FAISS index is stored (default: data/index)
# Please copy relative path of index file if error occurs
INDEX_DIR=data/index

# Optional: Port for the FastAPI server (default: 8000)
PORT=8000
